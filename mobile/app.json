{
  "expo": {
    "name": "Servix",
    "slug": "maidconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#1a1108"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.servix.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to log in to Servix quickly and securely."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1108"
      },
      "package": "world.servix.app",
      "versionCode": 13,
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "notification": {
        "icon": "./assets/icon.png",
        "color": "#C9A84C",
        "defaultChannel": "default"
      },
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "extra": {
      "API_URL": "https://api.servix.world/api",
      "eas": {
        "projectId": "aaf38d20-cf98-4589-b23d-1e6838133970"
      }
    },
    "plugins": [
      "./plugins/withAdiRegistration",
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C9A84C",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "owner": "testahmed570",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aaf38d20-cf98-4589-b23d-1e6838133970"
    }
  }
}
