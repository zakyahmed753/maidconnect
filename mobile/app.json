{
  "expo": {
    "name": "Servix",
    "slug": "maidconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.servix.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1108"
      },
      "package": "com.servix.app",
      "versionCode": 5,
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "extra": {
      "API_URL": "https://api.servix.world/api",
      "eas": {
        "projectId": "aaf38d20-cf98-4589-b23d-1e6838133970"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-asset"
    ],
    "owner": "testahmed570"
  }
}
